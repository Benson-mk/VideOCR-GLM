{
  "name": "videocr-glm-frontend",
  "version": "1.1.0",
  "description": "Frontend for VideOCR-GLM",
  "author": "Benson-mk",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/generate-versions.cjs && vite --mode dev --host",
    "dev:test": "node ../scripts/generate-versions.cjs && vite --mode test --host",
    "dev:prod": "node ../scripts/generate-versions.cjs && vite --mode prod --host",
    "build": "node ../scripts/generate-versions.cjs && vue-tsc --noEmit && vite --mode prod build",
    "build:dev": "node ../scripts/generate-versions.cjs && vue-tsc --noEmit && vite --mode dev build",
    "build:test": "node ../scripts/generate-versions.cjs && vue-tsc --noEmit && vite --mode test build",
    "preview": "vite preview --host",
    "lint": "eslint src",
    "format": "prettier --write src",
    "mirror:get": "npm config get registry",
    "mirror:set": "npm config set registry https://registry.npmmirror.com",
    "mirror:rm": "npm config rm registry",
    "up": "npx npm-check-updates -u"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@bassist/progress": "^0.2.2",
    "@bassist/utils": "^0.14.0",
    "ant-design-vue": "^4.2.6",
    "pinia": "^2.3.1",
    "uuid": "^13.0.0",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@bassist/eslint": "^0.7.1",
    "@bassist/tsconfig": "^0.1.1",
    "@bassist/uno": "^0.1.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@typescript-eslint/typescript-estree": "^8.18.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint": "^8.57.1",
    "husky": "^8.0.3",
    "less": "^4.2.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "typescript": "^5.7.2",
    "unocss": "^66.6.6",
    "unplugin-auto-import": "^0.17.3",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^7.3.1",
    "vite-plugin-banner": "^0.7.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,jsx,vue,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}